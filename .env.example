# Salin file ini ke .env dan isi semua nilai.
# Jangan pernah commit .env yang berisi secret sungguhan.

# Kunci SECRET Django. Generate lokal dengan:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# Boolean. Untuk production set ke False. Untuk development boleh True.
DEBUG=True

# Comma-separated list of hosts. Wajib di-set saat DEBUG=False.
# Contoh: "hospital.example.com,www.hospital.example.com"
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list dengan scheme+host, contoh:
#   "https://hospital.example.com"
# Hanya perlu kalau deploy di belakang proxy TLS.
DJANGO_CSRF_TRUSTED_ORIGINS=

# Kunci HMAC untuk signing prescription. Harus dibedakan dari
# DJANGO_SECRET_KEY agar rotasi SECRET_KEY tidak menginvalidasi signature
# rekam medis. Generate dengan:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
PRESCRIPTION_SIGNING_KEY=change-me

# Kunci enkripsi Fernet untuk PHI (diagnosis, treatment plan, notes).
# Generate dengan:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=generate-fernet-key-here
